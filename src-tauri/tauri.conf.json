{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "chara-graph",
  "version": "0.1.0",
  "identifier": "com.chara-graph.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "chara-graph",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-user-files-write-read",
          "description": "Allows the main window to write and read files and open file dialogs.",
          "windows": ["main"],
          "permissions": [
            "dialog:default",
            "fs:allow-write-file",
            "fs:allow-read-file",
            "fs:allow-mkdir",
            "fs:allow-read-text-file",
            "fs:allow-write-text-file"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
